name: diabetes-prediction

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_dir: {type: str, default: "diabetes_preprocessing"}
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 10}
      random_state: {type: int, default: 42}
    command: "python modelling.py --data_dir {data_dir} --n_estimators {n_estimators} --max_depth {max_depth} --random_state {random_state}"
